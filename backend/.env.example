# Salin file ini menjadi `.env` lalu isi nilainya.

# Google Drive API key — fallback untuk fitur download dari Google Drive.
# Fitur upload berjalan tanpa key ini.
# Dapatkan di https://console.cloud.google.com/ → enable "Google Drive API" → Credentials → API Key
GOOGLE_API_KEY=

# OAuth 2.0 (DIREKOMENDASIKAN untuk download Drive cepat, tanpa throttle).
# Cara isi: buat OAuth Client ID tipe "Desktop app" di Google Cloud Console
# (APIs & Services → Credentials), unduh JSON-nya, lalu jalankan:
#   cd backend && python scripts/get_drive_token.py <client_secret.json>
# Salin 3 nilai hasilnya ke bawah ini. User aplikasi TETAP tidak perlu login.
# Kalau ketiganya kosong, sistem otomatis pakai metode web-URL lama (lebih lambat).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Origin frontend yang diizinkan (CORS), dipisah koma.
# Default: http://localhost:5173,http://127.0.0.1:5173
# FRONTEND_ORIGINS=http://localhost:5173
