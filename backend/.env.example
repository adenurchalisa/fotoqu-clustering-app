# Salin file ini menjadi `.env` lalu isi nilainya.

# Google Drive API key — HANYA dibutuhkan untuk fitur download dari Google Drive.
# Fitur upload berjalan tanpa key ini.
# Dapatkan di https://console.cloud.google.com/ → enable "Google Drive API" → Credentials → API Key
GOOGLE_API_KEY=

# Origin frontend yang diizinkan (CORS), dipisah koma.
# Default: http://localhost:5173,http://127.0.0.1:5173
# FRONTEND_ORIGINS=http://localhost:5173
